68\u900d | \u501a\u5929\u5c60\u9f99\u8bb0 | \u5f39\u6307\u795e\u901a |\n| \u4ee4\u72d0\u51b2 | \u7b11\u50b2\u6c5f\u6e56 | \u72ec\u5b64\u4e5d\u5251 |\n| \u4efb\u76c8\u76c8 | \u7b11\u50b2\u6c5f\u6e56 | \u7434\u97f3\u5316\u5251 |\n| \u97e6\u5c0f\u5b9d | \u9e7f\u9f0e\u8bb0 | \u5316\u9aa8\u7ef5\u638c |\n| \u9648\u8fd1\u5357 | \u9e7f\u9f0e\u8bb0 | \u51dd\u78a7\u5251\u6cd5 |\n| \u80e1\u6590 | \u98de\u72d0\u5916\u4f20 | \u80e1\u5bb6\u5200\u6cd5 |\n| \u82d7\u82e5\u5170 | \u98de\u72d0\u5916\u4f20 | \u5170\u5fc3\u8559\u8d28 |\n| \u7a46\u5ff5\u6148 | \u5c04\u96d5\u82f1\u96c4\u4f20 | \u6768\u5bb6\u67aa\u6cd5 |\n\n## \u26a1 \u4e94\u884c\u6b66\u529f\u7cfb\u7edf\n\n32 \u95e8\u6b66\u529f\u5206\u5c5e\u4e94\u884c\uff0c**\u76f8\u514b\u500d\u7387 1.5x\uff0c\u88ab\u514b\u500d\u7387 0.7x**\uff1a\n\n```\n\u91d1 \u2192 \u6728 \u2192 \u571f \u2192 \u6c34 \u2192 \u706b \u2192 \u91d1\n```\n\n| \u4e94\u884c | \u4ee3\u8868\u6b66\u529f |\n|------|---------|\n| \ud83e\udd0d \u91d1 | \u516d\u8109\u795e\u5251\u3001\u72ec\u5b64\u4e5d\u5251\u3001\u5f39\u6307\u795e\u901a\u3001\u91d1\u521a\u4e0d\u574f\u4f53 |\n| \ud83d\udc9a \u6728 | \u9eef\u7136\u9500\u9b42\u638c\u3001\u5438\u661f\u5927\u6cd5\u3001\u5de6\u53f3\u4e92\u640f\u3001\u6253\u72d7\u68d2\u6cd5 |\n| \ud83d\udc99 \u6c34 | \u4e5d\u9634\u771f\u7ecf\u3001\u5317\u51a5\u795e\u529f\u3001\u51cc\u6ce2\u5fae\u6b65\u3001\u78a7\u6d77\u6f6e\u751f\u66f2 |\n| \u2764\ufe0f \u706b | \u4e5d\u9633\u795e\u529f\u3001\u4e00\u9633\u6307\u3001\u964d\u9f99\u5341\u516b\u638c |\n| \ud83d\udfe4 \u571f | \u4e7e\u5764\u5927\u632a\u79fb\u3001\u592a\u6781\u62f3\u3001\u592a\u6781\u5251\u6cd5\u3001\u5316\u9aa8\u7ef5\u638c |\n\n\u6700\u591a\u540c\u65f6\u6301\u6709 **5 \u95e8\u6b66\u529f**\uff0c\u6bcf\u95e8\u53ef\u4fee\u70bc\u81f3 **20 \u7ea7**\u3002\n\n## \u2694\ufe0f Boss \u6218\u6597\n\n### 50 \u4e2aBoss\uff0c\u96be\u5ea6\u9012\u8fdb\n\n| \u9636\u6bb5 | Boss \u8303\u4f8b | \u7b49\u7ea7\u533a\u95f4 |\n|------|----------|---------|\n| \u83dc\u9e1f\u671f | \u5c0f\u6bdb\u8d3c\u3001